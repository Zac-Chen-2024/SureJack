{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx vitest *)",
      "Bash(npx tsc *)",
      "Bash(npx tsx *)",
      "Bash(npx esbuild *)",
      "Bash(node *)",
      "Bash(ffmpeg *)",
      "Bash(ffprobe *)",
      "Bash(fc-list *)",
      "Bash(fc-match *)",
      "Bash(catdoc *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(file *)",
      "Bash(dig *)",
      "Bash(curl *)",
      "Read",
      "Edit(/root/SureJack/**)",
      "Write(/root/SureJack/**)"
    ],
    "ask": [
      "Bash(sudo *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(:(){*)",
      "Edit(/etc/nginx/**)",
      "Write(/etc/nginx/**)",
      "Edit(/root/SureJack/.env)",
      "Read(/root/SureJack/**/.env)"
    ]
  }
}
